<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d1a">

    <!-- ═══════════════════════════════════════════════ -->
    <!-- CONNECTION SCREEN                               -->
    <!-- ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/connectionScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎮 Steering Wheel"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="900° Mode"
            android:textSize="14sp"
            android:textColor="#666688"
            android:layout_marginBottom="48dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PC IP Address"
            android:textColor="#aaaacc"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/ipInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 192.168.1.100"
            android:inputType="text"
            android:textColor="#ffffff"
            android:textColorHint="#444466"
            android:background="#1a1a2e"
            android:padding="14dp"
            android:textSize="20sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Port"
            android:textColor="#aaaacc"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/portInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="5555"
            android:inputType="number"
            android:textColor="#ffffff"
            android:textColorHint="#444466"
            android:background="#1a1a2e"
            android:padding="14dp"
            android:textSize="20sp"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/connectButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/connect"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:backgroundTint="#4f46e5"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/disconnected"
            android:textColor="#666688"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- CONTROLLER SCREEN                               -->
    <!-- ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/controllerScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp"
        android:visibility="gone">

        <!-- Live angle display -->
        <TextView
            android:id="@+id/angleDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yaw: 0.0°"
            android:textColor="#4f46e5"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <!-- Centre status -->
        <TextView
            android:id="@+id/centreStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/centre_auto_set"
            android:textColor="#666688"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Set Centre button -->
        <Button
            android:id="@+id/setCentreButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/set_centre"
            android:textSize="15sp"
            android:textColor="#ffffff"
            android:backgroundTint="#1e1e3a"
            android:layout_marginBottom="32dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1e1e3a"
            android:layout_marginBottom="32dp"/>

        <!-- Indicators row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnLeftIndicator"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:text="@string/left_indicator"
                android:textSize="24sp"
                android:backgroundTint="#1a3a1a"
                android:alpha="0.5"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnRightIndicator"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:text="@string/right_indicator"
                android:textSize="24sp"
                android:backgroundTint="#1a3a1a"
                android:alpha="0.5"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- Lights + Cruise row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnLights"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:text="@string/lights"
                android:textSize="22sp"
                android:backgroundTint="#3a3a1a"
                android:alpha="0.5"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnCruise"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:text="@string/cruise"
                android:textSize="16sp"
                android:backgroundTint="#1a2a3a"
                android:alpha="0.5"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>